  "private": true,
  "dependencies": {
    "axios": "^1.5.0",
    "concurrently": "^8.2.2",
    "framer-motion": "^12.23.24",
    "http-proxy-middleware": "^2.0.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.16.0"
  },
  "scripts": {
